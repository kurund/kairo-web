# Copy to .env for local development.
# In production, the .env lives at /opt/kairo-web/app/.env (not under git).

KAIRO_SECRET_KEY=change-me-to-a-long-random-string
KAIRO_DATABASE_URL=sqlite:///./dev.db
KAIRO_BASE_URL=http://localhost:8001
KAIRO_OWNER_EMAIL=you@example.com
KAIRO_TIMEZONE=Europe/London

# Resend transactional email (free tier is fine for personal use).
# Leave RESEND_API_KEY blank in dev to log emails to stdout instead of sending.
RESEND_API_KEY=
RESEND_FROM_DOMAIN=kairo.example.com

LOG_LEVEL=INFO
